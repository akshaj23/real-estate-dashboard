%%writefile ai_dashboard.py
import streamlit as st
import pandas as pd
import ollama

# ==========================================
# 1. LOAD DATA & PREP CONTEXT
# ==========================================
df = pd.read_csv("leaseup_dashboard_data.csv")

market_txt = df.groupby('Market')['LeaseUpTime'].mean().round(2).to_string()
archetype_txt = df.groupby('Archetype')[['LeaseUpTime', 'Premium_to_Submarket_Pct']].mean().round(3).to_string()
submarket_txt = df.groupby('Submarket')['Premium_to_Submarket_Pct'].mean().sort_values(ascending=False).head(5).round(3).to_string()

# NEW: We are already injecting this context, but we want to make it highly specific.
top_props = df.sort_values('Premium_to_Submarket_Pct', ascending=False).groupby('Archetype').head(5)
top_props_txt = top_props[['Archetype', 'Submarket', 'Name']].to_string(index=False)

data_summary = f"""
Here is the Real Estate Investment Data Summary:

Overall Portfolio:
- Total Properties Analyzed: {len(df)}
- Average Lease-Up Time: {df['LeaseUpTime'].mean():.1f} months

Performance by Archetype (Lease-Up Time and Premium Percentage):
{archetype_txt}

Top 5 Highest Yielding Submarkets (Districts):
{submarket_txt}

Top Recommended Properties by Archetype and Submarket:
{top_props_txt}
"""

# ==========================================
# 2. DASHBOARD UI & SIDEBAR
# ==========================================
st.set_page_config(page_title="Investment AI Assistant", layout="wide")
st.title("🏙️ Real Estate Investment Dashboard")

with st.sidebar:
    st.header("Market Stats")
    st.dataframe(df.groupby('Archetype')['LeaseUpTime'].mean())
    st.write("Data processed and ready for NLP analysis.")

# ==========================================
# 3. GEOTAG Board (Interactive Map Explorer)
# ==========================================
# User Action: Remove the separator line for a cleaner look. We are removing 'st.write("---")'
st.subheader("📍 Geotag Board: Local Locality Explorer")
st.write("Filter by investment strategy and jump directly to specific properties on the map.")

# We now use three columns for the filters and map interaction:
# Archetype Filter (Col 1), Property Jumper (Col 2), Map (Col 3)
filter_col, jump_col, map_col = st.columns([1, 1, 3])

# Prep coordinates dataframe for map rendering
df_coords = df.dropna(subset=['Latitude', 'Longitude']).copy()

with filter_col:
    # Let the user filter by Archetype first (cluster filtering)
    options = ["All Properties"] + list(df['Archetype'].dropna().unique())
    selected_type = st.radio("Step 1: Filter by Strategy:", options, index=0, help="Filters the map and the property jumper list.")

# Initial filtering based on the Archetype radio
if selected_type == "All Properties":
    type_filtered_df = df_coords.copy()
else:
    type_filtered_df = df_coords[df_coords['Archetype'] == selected_type].copy()

with jump_col:
    # User Action: Addclickable feature.
    # We display Name and Submarket to handle duplicates (e.g., 'Grove' in different areas).
    # To do this, we create a temporary display label column.
    type_filtered_df['MapLabel'] = type_filtered_df['Name'] + " (" + type_filtered_df['Submarket'] + ")"
    
    # Dropdown options for jumping to specific building
    jump_options = ["📍 Show all buildings in this cluster"] + sorted(type_filtered_df['MapLabel'].tolist())
    selected_building = st.selectbox("Step 2: Click building to see locality:", jump_options, index=0, help="Instantially zooms map to the selected building.")

with map_col:
    # Final filter based on the specific building selection (or 'Show all' choice)
    if selected_building == "📍 Show all buildings in this cluster":
        map_df = type_filtered_df.copy()
    else:
        map_df = type_filtered_df[type_filtered_df['MapLabel'] == selected_building].copy()
    
    # Streamlit standard map column rename (needs lat/lon lowercase)
    map_df = map_df.rename(columns={'Latitude': 'lat', 'Longitude': 'lon'})
    
    if not map_df.empty:
        # Keep map_df lean for rendering
        map_df = map_df[['lat', 'lon']]
        st.map(map_df)
    else:
        # Should be covered by df_coords pre-processing, but safe.
        st.warning("No GPS coordinates found for this selection.")

# ==========================================
# 4. AI CHAT INTERFACE
# ==========================================
# User Action: Move question input one up (already removed separator, now chat is immediately beneath map section).
# I've also added a tip beneath the response to guide people back to the map jumping feature.
st.subheader("🤖 Ask the Investment Assistant")
user_input = st.text_input("Example: What is the best submarket to build an Urban Luxury High-Rise, and what are the top properties there?", key="input")

if user_input:
    with st.spinner("Thinking..."):
        prompt = f"""
        You are an expert Real Estate Investment Analyst. Use the following data summary to answer the user's question.
        
        DATA CONTEXT:
        {data_summary}
        
        USER QUESTION:
        {user_input}
        
        RESPONSE GUIDELINE:
        - Be concise, professional, and highly specific.
        - If asked for recommendations, you MUST rank the top Submarkets (districts) and list the SPECIFIC property names provided in the data.
        - Do not give generic advice. Give data-driven answers naming actual buildings and locations.
        - Do not hallucinate names or numbers.
        """
        
        try:
            response = ollama.chat(model='llama3', messages=[
                {'role': 'user', 'content': prompt},
            ])
            
            st.markdown("### Assistant Response:")
            st.write(response['message']['content'])
            st.info("💡 Tip: Use the Geotag Board explorer above to visually verify these specific submarkets and specific buildings.")
            
        except Exception as e:
            # Enhanced specific error for local Ollama setup on Mac
            if "[Errno 61]" in str(e):
                st.error("Error connecting to AI brain. Is the Ollama application open on your Mac (look for Llama icon in your top menu bar)?")
            else:
                st.error(f"Error connecting to AI: {e}")
